#!/bin/bash
set -euo pipefail

CONF=/etc/vpnroute/vpn-adapters.conf
POWERSHELL=/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe

if [ ! -x "$POWERSHELL" ]; then
  echo "ERROR: Windows PowerShell not found/executable at $POWERSHELL" >&2
  echo "  (needs WSL interop and access to the Windows filesystem)" >&2
  exit 1
fi
command -v jq >/dev/null 2>&1 || { echo "ERROR: required tool 'jq' not found in PATH" >&2; exit 1; }

mkdir -p /etc/vpnroute

echo "Discovering TAP-Windows adapters..."

# Previous config (absent on first run is an expected state, not an error).
OLD=""
[ -f "$CONF" ] && OLD="$(cat "$CONF")"

# Query the Windows host. Fails loudly if PowerShell errors (set -e); no stderr hidden.
JSON="$($POWERSHELL \
  "Get-NetAdapter | Where-Object { \$_.InterfaceDescription -like 'TAP-Windows*' } | Select-Object Name, InterfaceGuid | ConvertTo-Json")"

# No TAP-Windows adapters at all: explicit, visible failure.
if [ -z "$(printf '%s' "$JSON" | tr -d '[:space:]')" ]; then
    echo "ERROR: no TAP-Windows adapters found on the Windows host." >&2
    exit 1
fi

# Windows PowerShell's ConvertTo-Json emits a bare object for a single adapter
# and an array for multiple; normalise both to a stream of objects.
printf '%s' "$JSON" \
| jq -r '(if type == "array" then .[] else . end)
         | "\(.InterfaceGuid | ltrimstr("{") | rtrimstr("}") | ascii_downcase)  \(.Name)"' \
> "$CONF"

if [ ! -s "$CONF" ]; then
    echo "ERROR: adapter discovery produced no entries." >&2
    exit 1
fi

echo "Written to $CONF:"
cat "$CONF"

NEW=$(cat "$CONF")
if [ "$OLD" != "$NEW" ] && systemctl is-active --quiet wsl-vpnroute; then
    echo "Config changed — restarting wsl-vpnroute..."
    systemctl restart wsl-vpnroute
fi
